  "keyFeatures": [
    "Real-time sentiment analysis from X (Twitter), Reddit, and YouTube",
    "6-emotion classification using keyword-based analysis",
    "Crisis spike detection with volatility scoring",
    "AI-powered insights via Gemini/Groq with fallback to local analysis",
    "Scrape.do integration for reliable social media data fetching",
    "Scheduled topic monitoring with alerts",
    "CSV and PDF export capabilities",
    "Live feed with source status indicators",
    "Theme-based contextual analysis (geopolitical, energy, policy, tech, etc.)",
    "Supabase backend with PostgreSQL and Edge Functions"
  ],
